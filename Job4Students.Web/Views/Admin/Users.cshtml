@model IEnumerable<UserSummaryModel>
@{
    ViewData["Title"] = "Manage Users";
}
<h1>Manage Users</h1>
<form method="get" class="filter-bar">
    <select name="role"><option value="">Any role</option><option value="student">Student</option><option value="employer">Recruiter</option><option value="admin">Admin</option></select>
    <select name="status"><option value="">Any status</option><option value="active">Active</option><option value="inactive">Inactive</option><option value="suspended">Suspended</option></select>
    <button class="btn" type="submit">Filter</button>
</form>
<table>
<thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
<tbody>
@foreach (var user in Model)
{
    <tr>
        <td>@user.FullName<br /><span class="muted">@user.Username</span></td>
        <td>@user.Email</td>
        <td>@user.Role</td>
        <td>@user.Status</td>
        <td>
            <form asp-controller="Admin" asp-action="UpdateUserStatus" method="post" class="inline">
                <input type="hidden" name="id" value="@user.Id" />
                <select name="status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="suspended">Suspended</option></select>
                <button class="btn small" type="submit">Update</button>
            </form>
            @if (user.Role != "admin")
            {
                <form asp-controller="Admin" asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="inline" onsubmit="return confirm('Delete this user and all related records?')">
                    <button class="danger small" type="submit">Delete</button>
                </form>
            }
        </td>
    </tr>
}
</tbody>
</table>
